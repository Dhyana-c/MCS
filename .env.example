# Copy this file to .env (which is .gitignore'd) and fill in your real key.
#
# MCS_LLM_MODE selects how examples wire their LLM backend:
#   - mock (default): scripted MockLLM, no network calls, no API key needed
#   - real          : DeepSeekLLMPlugin, requires DEEPSEEK_API_KEY
#
# DeepSeek model IDs (per https://api-docs.deepseek.com/zh-cn/):
#   - deepseek-v4-flash   current, non-thinking mode (faster/cheaper)
#   - deepseek-v4-pro     current, thinking mode (deeper reasoning)
#   - deepseek-chat       DEPRECATED 2026-07-24 (alias of v4-flash non-thinking)
#   - deepseek-reasoner   DEPRECATED 2026-07-24 (alias of v4-flash thinking)

DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-v4-flash
MCS_LLM_MODE=mock

# MCS_LLM_PROVIDER selects which vendor backend `real` mode uses:
#   - deepseek (default): DeepSeekLLMPlugin (OpenAI-compatible), needs DEEPSEEK_API_KEY
#   - claude            : ClaudeLLMPlugin (Anthropic Messages), needs ANTHROPIC_AUTH_TOKEN
#                         install the optional dep first:  pip install -e ".[claude]"
MCS_LLM_PROVIDER=deepseek

# Anthropic / Claude backend (also works with Anthropic-compatible gateways
# by overriding ANTHROPIC_BASE_URL). ANTHROPIC_AUTH_TOKEN is a SECRET —
# never commit your real token; rotate it if it ever leaks.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
API_TIMEOUT_MS=600000
