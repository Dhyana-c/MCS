# Copy this file to .env (which is .gitignore'd) and fill in your real key.
#
# MCS_LLM_MODE selects how examples wire their LLM backend:
#   - mock (default): scripted MockLLM, no network calls, no API key needed
#   - real          : DeepSeekLLMPlugin, requires DEEPSEEK_API_KEY
#
# DeepSeek model IDs (per https://api-docs.deepseek.com/zh-cn/):
#   - deepseek-v4-flash   current, non-thinking mode (faster/cheaper)
#   - deepseek-v4-pro     current, thinking mode (deeper reasoning)
#   - deepseek-chat       DEPRECATED 2026-07-24 (alias of v4-flash non-thinking)
#   - deepseek-reasoner   DEPRECATED 2026-07-24 (alias of v4-flash thinking)

DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-v4-flash
MCS_LLM_MODE=mock
